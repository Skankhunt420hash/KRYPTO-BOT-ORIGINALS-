# ============================================================
# KRYPTO-BOT KONFIGURATION - Kopiere diese Datei zu .env
# ============================================================

# Exchange Zugangsdaten (z.B. Binance, Kraken, Bybit)
EXCHANGE=binance
API_KEY=dein_api_key_hier
API_SECRET=dein_api_secret_hier

# Trading-Modus: bevorzugt BOT_MODE (paper oder live)
# TRADING_MODE bleibt aus Kompatibilitätsgründen weiterhin unterstützt.
BOT_MODE=paper
TRADING_MODE=paper
# Safety-Guard: Live-Modus zusätzlich explizit freischalten
LIVE_TRADING_ENABLED=false

# App-Startschutz: verhindert parallele Instanzen (wichtig für Telegram Polling)
ENFORCE_SINGLE_INSTANCE=true
APP_INSTANCE_LOCKFILE=data/app.lock

# ============================================================
# MINIMALER WINDOWS-START (Paper + optional Telegram)
# Nur diese Werte müssen für den ersten lokalen Lauf stimmen:
#   BOT_MODE=paper
#   TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT
#   TIMEFRAME=1h
#   STRATEGY=auto
# Optional Telegram:
#   ENABLE_TELEGRAM=true
#   TELEGRAM_PANEL_ENABLED=true
#   TELEGRAM_BOT_TOKEN=<token>
#   TELEGRAM_CHAT_ID=<chat_id>
# ============================================================

# Handelspaare (kommagetrennt)
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT

# Zeitrahmen (1m, 5m, 15m, 1h, 4h, 1d)
TIMEFRAME=1h

# Risiko-Einstellungen
MAX_POSITION_SIZE_PERCENT=2.0
MAX_OPEN_TRADES=5
STOP_LOSS_PERCENT=2.0
TAKE_PROFIT_PERCENT=4.0
TRAILING_STOP=false

# Startkapital (nur für Paper-Trading)
PAPER_TRADING_BALANCE=10000.0

# Strategie: rsi_ema, macd_crossover, combined, auto
# auto = Multi-Strategy-Modus mit Meta-Selector (empfohlen)
STRATEGY=auto

# Telegram Hauptschalter:
# - bevorzugt ENABLE_TELEGRAM
# - TELEGRAM_ENABLED bleibt für Alt-Konfigurationen kompatibel
ENABLE_TELEGRAM=false
TELEGRAM_ENABLED=false

# Benachrichtigungen global an/aus
ENABLE_NOTIFICATIONS=true

# Telegram Zugangsdaten
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Nur Signale ab dieser Konfidenz senden (0-100)
TELEGRAM_MIN_CONFIDENCE=50
# Benachrichtigungslevel: off | critical | trading | all
TELEGRAM_NOTIFY_LEVEL=trading
# Cooldown für wiederholte Error-Alerts (Sekunden)
TELEGRAM_ERROR_ALERT_COOLDOWN_SEC=120

# Telegram-Control-Panel (optional, standardmäßig aus)
TELEGRAM_PANEL_ENABLED=false
TELEGRAM_PANEL_POLL_INTERVAL_SEC=10
TELEGRAM_PANEL_LOG_LINES=20
# Kommagetrennte Chat-/User-IDs für Panel-Whitelist (leer = keine Whitelist)
TELEGRAM_PANEL_ALLOWED_IDS=

# Datenbankpfad
DATABASE_URL=sqlite:///data/trades.db

# Log-Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================
# MULTI-STRATEGY / RISK ENGINE EINSTELLUNGEN
# ============================================================

# Tagesverlust-Limit in % des Startkapitals (danach Pause)
DAILY_LOSS_LIMIT_PCT=5.0

# Wartezeit nach Schließung einer Position auf demselben Coin (Minuten)
COIN_COOLDOWN_MINUTES=60

# Wartezeit nach Verlust-Trade für dieselbe Strategie (Minuten)
STRATEGY_COOLDOWN_MINUTES=30

# Duplikat-Signal-Schutz: gleiche Strategie + Symbol in N Minuten
DUPLICATE_SIGNAL_MINUTES=15

# Mindest-Konfidenz für Signale (0-100)
MIN_CONFIDENCE=40.0

# Mindest-RR für Signale
MIN_RR=1.5

# Brain-Gate (kontrollierte adaptive Entscheidungslogik)
# Signal-Score unterhalb dieses Werts wird nicht gehandelt
BRAIN_MIN_SCORE_TO_TRADE=0.45
# Unterhalb dieses Scores gilt die Marktphase als "riskant/unsauber"
BRAIN_RISKY_PHASE_SCORE=0.35

# ============================================================
# PORTFOLIO RISK ENGINE & POSITION SIZING
# ============================================================

# Position-Sizing-Modus: fixed_notional | fixed_risk_pct | confidence_scaled
#   fixed_notional:    Fester USDT-Betrag pro Trade (FIXED_NOTIONAL_USD)
#   fixed_risk_pct:    Risiko-basiert: Betrag so dass SL-Verlust = RISK_PER_TRADE_PCT% (empfohlen)
#   confidence_scaled: Wie fixed_risk_pct, aber Menge skaliert mit Signal-Konfidenz
POSITION_SIZING_MODE=fixed_risk_pct

# Fester USDT-Betrag pro Trade (nur für fixed_notional)
FIXED_NOTIONAL_USD=200.0

# Risiko pro Trade in % des Kontos (für fixed_risk_pct + confidence_scaled)
# Beispiel: 1% von 10.000 USDT = 100 USDT Risiko → bei SL-Auslösung max 100 USDT Verlust
RISK_PER_TRADE_PCT=1.0

# Mindest- / Maximal-Positionsgröße in USDT
MIN_POSITION_NOTIONAL=10.0
MAX_POSITION_NOTIONAL=5000.0

# Skalierungsgrenzen für confidence_scaled (Faktor auf das Basis-Risiko)
CONFIDENCE_MIN_SCALE=0.5
CONFIDENCE_MAX_SCALE=1.5

# Max. Portfolio-Risiko: Summe aller offenen SL-Risiken (% des Kapitals)
MAX_TOTAL_OPEN_RISK_PCT=10.0

# Max. Anzahl gleichzeitiger Positionen (gesamt / pro Symbol / pro Strategie)
MAX_POSITIONS_TOTAL=5
MAX_POSITIONS_PER_SYMBOL=1
MAX_STRATEGY_POSITIONS=2

# Max. % der Positionen in gleicher Richtung (z.B. 80% = max 4 von 5 LONGs)
MAX_SAME_DIRECTION_EXPOSURE_PCT=80.0

# Max. Risiko (% des Kapitals) innerhalb eines Symbol-Clusters
# Standard-Cluster: BTC/ETH = "majors", alles andere = "alts"
MAX_CLUSTER_RISK_PCT=6.0

# ============================================================
# EXECUTION QUALITY LAYER & FAIL-SAFES
# ============================================================

# Anzahl der Wiederholungsversuche bei temporären Fehlern (Timeout, Netzwerk)
EXECUTION_MAX_RETRIES=3

# Initiale Wartezeit (Sekunden) zwischen Retries – verdoppelt sich exponentiell
# Versuch 1: 2s | Versuch 2: 4s | Versuch 3: 8s
EXECUTION_RETRY_BACKOFF_SEC=2.0

# Max. erlaubte Preisabweichung zwischen Signal-Entry und aktuellem Preis (%)
# 0.0 = Prüfung deaktiviert | 0.5 = max 0.5% Abweichung erlaubt
MAX_ENTRY_DEVIATION_PCT=0.5

# Anzahl der Slippage-Events in einem Fenster bevor Emergency Pause
MAX_SLIPPAGE_EVENTS_WINDOW=5

# Anzahl aufeinanderfolgender Exchange-Fehler bis Circuit Breaker auslöst
MAX_CONSECUTIVE_EXEC_ERRORS=5

# Anzahl aufeinanderfolgender Rejections (Slippage/Duplicate) bis Pause
MAX_CONSECUTIVE_REJECTIONS=10

# Bei Execution-Fehlern Bot automatisch pausieren
EMERGENCY_PAUSE_ON_EXEC_ERRORS=true

# Cooldown-Zeit des Circuit Breakers in Sekunden (Standard: 5 Minuten)
CIRCUIT_BREAKER_COOLDOWN_SEC=300

# Kill-Switch-Datei: Bot stoppt wenn diese Datei existiert
# Aktivieren: touch ./KILL_SWITCH | Deaktivieren: rm ./KILL_SWITCH
KILL_SWITCH_FILE=./KILL_SWITCH

# ============================================================
# HEALTH MONITOR & WATCHDOG
# ============================================================

# Health-Monitoring global aktivieren
HEALTH_MONITOR_ENABLED=true

# Zeit (Sekunden) ohne Heartbeat bevor Warnung ausgelöst wird
# Heartbeat wird zu Beginn jedes run_cycle() gesetzt
HEALTH_HEARTBEAT_TIMEOUT_SEC=300

# Maximales Alter (Sekunden) von OHLCV-Daten bevor "stale" gilt
# 1h-Zeitrahmen: ~4000s | 5m-Zeitrahmen: ~600s
DATA_STALE_TIMEOUT_SEC=600

# Wie oft Health-Snapshots geloggt werden (Sekunden)
HEALTH_CHECK_INTERVAL_SEC=300

# Fehler-Rolling-Zeitfenster (Minuten)
ERROR_WINDOW_MINUTES=30

# Maximale Fehler im Zeitfenster bis Status DEGRADED
MAX_ERRORS_PER_WINDOW=20

# Maximale kritische Fehler im Zeitfenster bis Status ERROR
MAX_CRITICAL_ERRORS_PER_WINDOW=5

# Mindestabstand zwischen gleichen Telegram-Health-Alerts (Sekunden)
TELEGRAM_ALERT_COOLDOWN_SEC=300

# Trading pausieren bei stale Daten (konservativ: false)
HEALTH_PAUSE_ON_STALE_DATA=false

# Trading pausieren bei Heartbeat-Miss (konservativ: false)
HEALTH_PAUSE_ON_HEARTBEAT_MISS=false

# Ressourcenüberwachung via psutil (pip install psutil)
RESOURCE_MONITOR_ENABLED=true
MAX_MEMORY_PCT=80.0
MAX_CPU_PCT=90.0
